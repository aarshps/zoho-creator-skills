#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)"

case "${1:-get}" in
  get) ;;
  store|erase) exit 0 ;;
  *) exit 0 ;;
esac

protocol=""
host=""

while IFS='=' read -r key value; do
  [[ -z "${key}" ]] && break

  case "${key}" in
    protocol) protocol="${value}" ;;
    host) host="${value}" ;;
  esac
done

if [[ "${protocol}" != "https" || "${host}" != "github.com" ]]; then
  exit 0
fi

token="$("${SCRIPT_DIR}/resolve-aarshps-github-token")"

printf 'username=%s\n' 'aarshps'
printf 'password=%s\n\n' "${token}"
