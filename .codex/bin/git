#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)"
PROJECT_ROOT="$(CDPATH= cd -- "${SCRIPT_DIR}/../.." && pwd)"
REAL_GIT="/usr/bin/git"
LOCAL_GIT_CONFIG="${PROJECT_ROOT}/.codex/gitconfig"

exec env \
  GIT_AUTHOR_NAME="aarshps" \
  GIT_AUTHOR_EMAIL="aarshps@gmail.com" \
  GIT_COMMITTER_NAME="aarshps" \
  GIT_COMMITTER_EMAIL="aarshps@gmail.com" \
  GIT_CONFIG_GLOBAL="${LOCAL_GIT_CONFIG}" \
  GIT_TERMINAL_PROMPT=0 \
  "${REAL_GIT}" "$@"
